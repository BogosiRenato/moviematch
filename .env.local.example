# Optional: TMDB API key for real movie data.
# Without this, the app uses a hardcoded fallback list.
# Get a key from https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Required: Upstash Redis (REST) for the room store.
# Create a free database at https://upstash.com/ and copy these from the dashboard.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: override the region detected for room members during local dev.
# In production we read x-vercel-ip-country from the request headers; locally
# that header is absent, so DEFAULT_REGION acts as the dev fallback. If unset,
# we fall back further to 'BW'. ISO 3166-1 alpha-2, uppercase (e.g. US, GB, ZA).
DEFAULT_REGION=

# Optional: set to any non-empty value to log provider cache hits/misses.
# DEBUG_PROVIDERS=1
